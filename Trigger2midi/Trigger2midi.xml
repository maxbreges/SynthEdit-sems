<?xml version="1.0" encoding="UTF-8"?>
<PluginList>
    <Plugin id="My trigger2midi" name="trigger2midi" category="mx/MIDI">
        <Audio>
            <Pin name="Trigger" datatype="bool"/>
            <Pin name="Gate" datatype="bool"/>
            <Pin name="Pitch" datatype="float" rate="audio"/>
            <Pin name="Velocity" datatype="float" rate="audio"/>
            <Pin name="Channel" datatype="int" default="1"/>
            <Pin name="MIDI Out" datatype="midi" direction="out"/>
        </Audio>
    </Plugin>
</PluginList>
